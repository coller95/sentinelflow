from typing import Any, Dict, Type, TypeVar, Optional, List, Callable

class BaseModel:
    def __init__(self, **data: Any) -> None: ...
    def dict(self, *args: Any, **kwargs: Any) -> Dict[str, Any]: ...
    def json(self, *args: Any, **kwargs: Any) -> str: ...
    def model_dump(self, *args: Any, **kwargs: Any) -> Dict[str, Any]: ...  # Pydantic v2
    @classmethod
    def model_validate(cls, obj: Any) -> Any: ... # Pydantic v2

def model_validator(*args: Any, **kwargs: Any) -> Any: ...
